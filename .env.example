# Environment variables – Tapo NVR Stack (8-camera)
# Copy this file to .env and fill in your real values.
# .env is gitignored – never commit credentials.

# ── Tapo camera RTSP credentials ─────────────────────────────────────────────
# Set these in the Tapo app: Camera Settings → Advanced → Camera Account
CAM_USER=change_me_username
CAM_PASS=change_me_password

# ── MQTT broker credentials ───────────────────────────────────────────────────
# Used by Mosquitto (hashed at startup), Frigate, and any MQTT subscribers.
# Anonymous access is DISABLED – you MUST change these before deployment.
MQTT_USER=nvr
MQTT_PASSWORD=change_me_mqtt_password
