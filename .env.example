# Environment variables – Tapo NVR Stack
# Copy this file to .env and fill in your real values.
# .env is gitignored – never commit credentials.

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/New_York

# ── Tapo camera RTSP credentials ─────────────────────────────────────────────
# Set these in the Tapo app: Advanced → Camera Account
CAMERA_USER=admin
CAMERA_PASSWORD=changeme

# ── Camera IP addresses ───────────────────────────────────────────────────────
CAM1_IP=192.168.1.101
CAM2_IP=192.168.1.102
CAM3_IP=192.168.1.103
CAM4_IP=192.168.1.104
